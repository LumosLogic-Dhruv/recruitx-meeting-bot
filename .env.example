RECALL_API_KEY=your_recall_api_key
RECALL_API_URL=https://ap-northeast-1.recall.ai/api/v1
OPENAI_API_KEY=your_openai_api_key
RENDER_URL=https://recruitx-meeting-bot.onrender.com

# Optional — pass your Deepgram key here, or configure it in the Recall.ai dashboard
DEEPGRAM_API_KEY=your_deepgram_api_key

# Model Configurations
DEEPGRAM_MODEL=nova-3
ELEVENLABS_MODEL_ID=eleven_flash_v2_5
OPENAI_MODEL=gpt-4o-mini
OPENAI_EVAL_MODEL=gpt-4o
OPENAI_SCORECARD_MODEL=gpt-4o

# ── Google Calendar + Gmail (for meeting link generation & email invites) ──────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_SENDER_EMAIL=interviews@lumoslogic.com   # email address that sends interview invites
COMPANY_NAME=LumosLogic                         # shown in email subject and body
