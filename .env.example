RECALL_API_KEY=your_recall_api_key
RECALL_API_URL=https://ap-northeast-1.recall.ai/api/v1
OPENAI_API_KEY=your_openai_api_key
RENDER_URL=https://your-app-name.onrender.com

# Optional — pass your Deepgram key here, or configure it in the Recall.ai dashboard
DEEPGRAM_API_KEY=your_deepgram_api_key

# Model Configurations (Optimized for human-like flow, sub-2s latency & high technical accuracy)
DEEPGRAM_MODEL=nova-3                  # Highest accuracy STT model (default: nova-3)
ELEVENLABS_MODEL_ID=eleven_flash_v2_5   # Ultra-low latency (~75ms) TTS model (default: eleven_flash_v2_5)
OPENAI_MODEL=gpt-4o-mini                # Real-time live turns for sub-second TTFT (default: gpt-4o-mini)
OPENAI_EVAL_MODEL=gpt-4o               # Asynchronous background turn evaluation (default: gpt-4o)
OPENAI_SCORECARD_MODEL=gpt-4o          # Comprehensive candidate hiring scorecard (default: gpt-4o)
